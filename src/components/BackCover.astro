---
interface Props {
  title: string;
  issue: string;
  date: string;
  tagline: string;
  img: string;
}
const { title, issue, date, tagline, img } = Astro.props;
---
<div class="back-cover">
  <img src={img} alt="" />
  <div class="cover-overlay">
    <div class="back-cover-tagline">{tagline}</div>
    <div class="cover-title">{title}</div>
    <div class="cover-issue-line">Issue {issue} — {date}</div>
    <div class="cover-rule"></div>
  </div>
</div>
